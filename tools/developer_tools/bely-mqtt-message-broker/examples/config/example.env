# BELY MQTT Framework Configuration Example
# Copy this file to .env and update with your values

# MQTT Configuration
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=bely/#

# BELY API Configuration (optional)
BELY_API_URL=https://api.bely.dev
BELY_API_KEY=your-api-key-here

# Logging
LOG_LEVEL=INFO

# Handler Configuration
HANDLERS_DIR=./handlers